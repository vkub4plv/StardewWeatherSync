{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  // Get your API key from https://home.openweathermap.org/api_keys
  "ApiKey": "SECRET",
  // Get your latitude and longitude from https://www.latlong.net/
  "Latitude": 0.0,
  "Longitude": 0.0,
  // Set how often the application should poll the OpenWeatherMap API for updates, in minutes. Adjust this value as needed, but keep in mind that the free tier of the API has a limit of 60 calls per minute.
  "PollMinutes": 5,
  // If you want to delay the startup of the application to ensure that your internet connection is established and the Wallpaper Engine is running, set the delay in seconds here. Adjust this value as needed based on your system's startup time.
  "StartupDelaySeconds": 30,
  // If you have multiple monitors and want to specify which one to use, set the index here (0 for primary monitor, 1 for secondary, etc.). If you only have one monitor, leave this as 0.
  "MonitorIndex": 0,
  // Set the path to your Wallpaper Engine executable. If you have it installed on a different drive or in a different folder, update this path accordingly.
  "WallpaperExecutablePath": "C:\\Program Files (x86)\\Steam\\steamapps\\common\\wallpaper_engine\\wallpaper64.exe",
  "StateFile": "last-state.json",

  // Threshold temperatures in Celsius for determining which outfit to use based on the current weather conditions. Adjust these values as needed to better fit your preferences and local climate.
  "WinterOutfitThresholdC": 5.0,
  "BeachOutfitThresholdC": 24.0,

  // Penalties in Celsius to apply to the temperature when determining the outfit for certain weather conditions. These values can be adjusted to better reflect how different weather conditions affect your comfort level.
  "LightRainWinterPenaltyC": 2.0,
  "RainWinterPenaltyC": 4.0,
  "GreenRainWinterPenaltyC": 4.0,
  "StormWinterPenaltyC": 5.0,
  "SnowWinterPenaltyC": 8.0,

  // Chance for green rain to occur, expressed as a decimal between 0 and 1. Adjust this value to increase or decrease the likelihood of green rain. Higher values will result in more frequent green rain, while lower values will make it rarer.
  "GreenRainChance": 0.25
}
